# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin CMS (local password auth; default is admin123)
ADMIN_PASSWORD=admin123

# Optional: Supabase (SQL migrations included; app uses local JSON store by default)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: OpenAI for AI draft generation (falls back to local draft stub)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
